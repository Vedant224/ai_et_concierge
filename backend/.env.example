# Gemini API key for LLM calls (preferred)
GEMINI_API_KEY=your_gemini_api_key_here

# Gemini model name
GEMINI_MODEL=gemini-2.5-flash-lite

# Backward-compatible alias (optional if GEMINI_API_KEY is set)
GOOGLE_API_KEY=

# Optional absolute or relative path to catalog JSON
CATALOG_PATH=backend/data/et_catalog.json

# Frontend origins allowed by CORS (comma-separated)
CORS_ORIGINS=http://localhost:3000
